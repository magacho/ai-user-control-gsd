# Spring Profile
SPRING_PROFILE=dev

# Database Configuration
DATABASE_URL=jdbc:postgresql://localhost:5432/aiusercontrol
DATABASE_USERNAME=postgres
DATABASE_PASSWORD=postgres

# Server Configuration
SERVER_PORT=8080

# Google OAuth2 Configuration
GOOGLE_CLIENT_ID=your-google-client-id-here
GOOGLE_CLIENT_SECRET=your-google-client-secret-here

# Admin User
ADMIN_EMAIL=admin@bemobi.com

# Claude API Configuration
CLAUDE_API_URL=https://api.anthropic.com/v1
CLAUDE_API_KEY=your-claude-api-key-here
CLAUDE_INTEGRATION_ENABLED=false

# GitHub Copilot Configuration
GITHUB_API_URL=https://api.github.com
GITHUB_API_TOKEN=your-github-token-here
GITHUB_ORG=bemobi
GITHUB_INTEGRATION_ENABLED=false

# Google Workspace Configuration
GWS_ENABLED=false
GWS_SERVICE_ACCOUNT_KEY_PATH=/path/to/google-workspace-key.json
GWS_DELEGATED_ADMIN_EMAIL=admin@bemobi.com
GWS_DOMAIN=bemobi.com

# Cursor Configuration
CURSOR_API_URL=https://api.cursor.com
CURSOR_API_KEY=your-cursor-api-key-here
CURSOR_INTEGRATION_ENABLED=false

# Email Configuration
EMAIL_ENABLED=false
EMAIL_FROM=noreply@bemobi.com
EMAIL_ADMIN_RECIPIENTS=admin@bemobi.com

# Scheduler Configuration
SCHEDULER_ENABLED=true
USAGE_METRICS_CRON=0 0 2 * * ?
INACTIVE_ACCOUNTS_CRON=0 0 3 * * ?
INACTIVE_DAYS_THRESHOLD=30
